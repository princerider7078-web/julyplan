# Copy this file to keystore.properties and fill in your values.
# keystore.properties is gitignored — never commit real credentials.
#
# To generate a keystore:
#   keytool -genkeypair -v -keystore july-plan-release.keystore \
#     -alias july-plan -keyalg RSA -keysize 2048 -validity 10000
#
# Place the .keystore file in android/keystore/ (also gitignored).

storeFile=../keystore/july-plan-release.keystore
storePassword=your-keystore-password
keyAlias=july-plan
keyPassword=your-key-password
