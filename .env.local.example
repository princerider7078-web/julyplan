# July Plan V3.1 — Environment Variables
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real credentials.

# ─── Required: Supabase ───
# Public anon key — safe for frontend (protected by RLS)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ─── Required: AI Provider (pick ONE) ───
# The /api/ai route auto-detects which provider to use based on which key is set.
# Priority: OPENROUTER > GROQ > OPENAI > GEMINI > ZAI_PUBLIC > z-ai-sdk (sandbox)

# Option 1: Groq (FREE, fast, recommended) — https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_key

# Option 2: OpenRouter (FREE models available) — https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key

# Option 3: Google Gemini (FREE) — https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=AIzaSy_your_gemini_key

# Option 4: OpenAI (paid) — https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-proj-your_openai_key

# Option 5: Z.ai public API (if you have credentials)
# ZAI_API_KEY=your_zai_api_key
# ZAI_BASE_URL=https://api.z.ai/v1

# ─── Optional: Site URL (for APK + OpenRouter referer header) ───
# NEXT_PUBLIC_SITE_URL=https://your-vercel-url.vercel.app
