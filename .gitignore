# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# typescript
*.tsbuildinfo
next-env.d.ts

# env files (secrets — never commit)
.env
.env.local
.env*.local
.env.production
.env.production.local

# Keep example templates
!.env.local.example

# Android build artifacts
android/app/build/
android/build/
android/.gradle/
android/local.properties
android/captures/
android/app/release/
*.apk
*.aab
*.ap_
*.dex

# Android signing secrets — NEVER commit
android/keystore/
*.keystore
*.jks
keystore.properties

# SQLite database
db/
*.db

# Logs
dev.log
server.log
*.log

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
Thumbs.db

# Capacitor
android/app/src/main/assets/public/

# Skill definitions (environment-provided, not part of app source)
skills/

# Auto-generated Android test stubs
android/app/src/test/
android/app/src/androidTest/
